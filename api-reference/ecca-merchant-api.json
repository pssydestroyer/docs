          "external_id",
          "customer_id",
          "purpose",
          "amount",
          "amount_to_send",
          "currency",
          "status",
          "callback_url",
          "success_url",
          "fail_url",
          "payment_url",
          "created_at",
          "expires_at",
          "finished_at",
